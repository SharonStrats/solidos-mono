{
  "name": "chat-pane",
  "version": "3.0.4-2",
  "description": "Solid-compatible Panes: Chat",
  "main": "dist/index.cjs.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run typecheck && npm run clean && vite build",
    "watch": "vite build --watch",
    "lint": "eslint",
    "lint-fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck-test && vitest run",
    "test-coverage": "vitest run --coverage",
    "typecheck-test": "tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "npm run build && npm run lint && npm run test",
    "preversion": "npm run lint && npm run typecheck && npm run test",
    "start": "vite"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SolidOS/chat-pane.git"
  },
  "keywords": [
    "solid",
    "chat",
    "message",
    "discusssion",
    "decentralized",
    "web",
    "rdf",
    "ldp",
    "linked",
    "pane",
    "app",
    "data"
  ],
  "author": "Tim Berners-Lee <timbl@mit.edu>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SolidOS/chat-pane/issues"
  },
  "homepage": "https://github.com/SolidOS/chat-pane",
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@typescript-eslint/parser": "^8.53.1",
    "buffer": "^6.0.3",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "jsdom": "^29.1.1",
    "neostandard": "^0.13.0",
    "pane-registry": "workspace:*",
    "solidos-toolkit": "dev",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "pane-registry": "workspace:*",
    "patch-package": "^8.0.1",
    "rdflib": "^2.3.9",
    "solid-logic": "workspace:*",
    "solid-ui": "workspace:*",
    "vite": "^8.0.16",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  },
  "solidosDependencies": [
    "solid-ui",
    "pane-registry"
  ],
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
